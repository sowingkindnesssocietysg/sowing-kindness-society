---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout>

<!-- ── HERO ── -->
<section id="hero" style="padding:48px 0 0;position:relative;overflow:hidden">
  <div class="container">
    <div class="grid-2col" style="gap:40px">
      <div>
        <h1 id="hero-heading" style="font:700 clamp(38px,5vw,64px)/1.06 var(--serif);letter-spacing:-.02em;margin:0">
          <span class="word" style="color:var(--ink-900);display:inline-block">Inspiring</span>{' '}
          <span class="word" style="color:var(--orange-500);display:inline-block">Young</span><br/>
          <span class="word" style="color:var(--ink-900);display:inline-block">Storytellers to</span><br/>
          <span class="word" style="color:var(--forest-800);display:inline-block">Sow Kindness</span>
        </h1>
        <div id="hero-sub" style="display:flex;align-items:center;gap:12px;margin:20px 0 20px">
          <span style="width:28px;height:1.5px;background:var(--sage-500);display:inline-block;flex-shrink:0"></span>
          <span style="font:600 15px var(--sans);color:var(--forest-800)">Storytelling Competition 2026</span>
          <span style="width:28px;height:1.5px;background:var(--sage-500);display:inline-block;flex-shrink:0"></span>
        </div>
        <div id="hero-tagline" style="display:flex;align-items:flex-start;gap:12px;margin-bottom:14px" class="hide-mobile">
          <img src="/logo/sks-logomark.png" alt="" width="44" height="44" style="height:44px;width:auto;flex-shrink:0" />
          <div>
            <div style="font:700 19px/1.3 var(--serif);color:var(--forest-800)">Sow Kindness, Watch It Grow</div>
            <div style="font:500 16px/1.3 var(--sans);color:var(--fern-600);margin-top:3px">播撒善意,静待花开</div>
          </div>
        </div>
        <p id="hero-body" style="font:400 16px/1.6 var(--sans);color:var(--ink-700);max-width:480px;margin-bottom:28px">
          A bilingual storytelling competition for children aged 3–6. Share a story from your heart and inspire others with kindness.
        </p>
        <div id="hero-btns" style="display:flex;gap:12px;flex-wrap:wrap">
          <a href="/competition/" class="btn btn-secondary">View Competition <span class="chev">›</span></a>
          <a href="/submit/" class="btn btn-primary">Submit Video <span class="chev">›</span></a>
        </div>
      </div>

      <div id="hero-img" style="position:relative;min-height:460px">
        <span class="float-heart" style="top:40px;left:80px;font-size:18px">♥</span>
        <span class="float-heart" style="top:80px;left:160px;font-size:14px;animation-delay:1s">♥</span>
        <span class="float-seed"  style="top:60px;right:60px;font-size:18px">✻</span>
        <div style="position:absolute;top:-60px;right:-40px;width:130%;aspect-ratio:1302/1208;-webkit-mask-image:url(/illustrations/hero-blob-mask.svg);mask-image:url(/illustrations/hero-blob-mask.svg);-webkit-mask-size:100% 100%;mask-size:100% 100%;-webkit-mask-repeat:no-repeat;mask-repeat:no-repeat"
          id="hero-blob">
          <img src="/illustrations/storytellers-mic.png" alt="Young storytellers"
            style="width:100%;height:100%;object-fit:cover;display:block"
            loading="eager" />
        </div>
      </div>
    </div>

    <!-- Stats bar -->
    <div id="stats-bar" style="margin-top:28px;padding-bottom:64px;position:relative;z-index:10">
      <div class="card card--quiet stats-bar">
        <div class="stat-item">
          <span class="stat-icon" style="background:linear-gradient(135deg,var(--fern-600) 55%,var(--orange-500) 55%);color:#fff;font:700 11px var(--sans)">A文</span>
          <div><div class="stat-label" style="color:var(--forest-800)">EN & 中文</div><div class="stat-sub">Bilingual</div></div>
        </div>
        <div class="stat-item">
          <span class="stat-icon" style="background:var(--sage-200)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--forest-800)" stroke-width="2" stroke-linecap="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 3a4 4 0 100 8 4 4 0 000-8z"/></svg>
          </span>
          <div><div class="stat-label" style="color:var(--forest-800)">Ages 3–6</div><div class="stat-sub">Storytellers</div></div>
        </div>
        <div class="stat-item">
          <span class="stat-icon" style="background:var(--sage-200)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--forest-800)" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </span>
          <div><div class="stat-label" style="color:var(--forest-800)">20 Sep 2026</div><div class="stat-sub">Deadline</div></div>
        </div>
        <div class="stat-item">
          <span class="stat-icon" style="background:var(--orange-100)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--orange-600)" stroke-width="2" stroke-linecap="round"><path d="M6 9H4.5a2.5 2.5 0 010-5H6M18 9h1.5a2.5 2.5 0 000-5H18M4 22h16M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22M18 2H6v7a6 6 0 0012 0V2z"/></svg>
          </span>
          <div><div class="stat-label" style="color:var(--orange-600)">Nov 2026</div><div class="stat-sub">Grand Final</div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── ABOUT ── -->
<section class="section section--cream">
  <div class="container grid-2col" data-stagger>
    <div data-fade>
      <h2 style="font:700 clamp(32px,4.8vw,64px)/1.08 var(--serif);letter-spacing:-.015em;margin:0">
        <span style="color:var(--ink-900)">About</span><br/>
        <span style="color:var(--forest-800)">Sowing Kindness</span><br/>
        <span style="color:var(--orange-500)">Society</span>
      </h2>
      <div style="display:flex;align-items:center;gap:10px;margin:18px 0 16px">
        <span style="font:600 17px var(--serif);color:var(--fern-600)">Nurturing kindness in children, families and communities.</span>
        <span style="color:var(--heart)">♥</span>
      </div>
      <p style="font:400 16px/1.7 var(--sans);color:var(--ink-700);margin-bottom:24px;max-width:460px">
        Sowing Kindness Society began as a small circle of parents, educators and storytellers who believe kindness can be grown in our youngest children — one moment, one story, one act at a time.
      </p>
      <a href="/about/" class="btn btn-primary">Learn More <span class="chev">›</span></a>
    </div>
    <div data-fade class="hide-mobile" style="position:relative;width:120%;margin-left:-10%;aspect-ratio:1045/941;-webkit-mask-image:url(/illustrations/section-2-blob-mask.svg);mask-image:url(/illustrations/section-2-blob-mask.svg);-webkit-mask-size:100% 100%;mask-size:100% 100%;-webkit-mask-repeat:no-repeat;mask-repeat:no-repeat">
      <img src="/illustrations/section-2-about.png" alt="" style="width:100%;height:100%;object-fit:cover" loading="lazy" />
    </div>
  </div>
</section>

<!-- ── MVV ── -->
<section class="section" style="overflow:hidden">
  <div class="container" style="text-align:center">
    <img data-fade src="/logo/sks-logo-transparent.png" alt="" width="120" height="120" style="height:120px;width:auto;margin:0 auto 16px" loading="lazy" />
    <div data-fade style="font:600 18px var(--serif);color:var(--fern-600);margin-bottom:10px">Guiding everything we do</div>
    <h2 data-fade style="font:700 clamp(28px,4.5vw,60px)/1.1 var(--serif);margin:0 0 12px">
      <span style="color:var(--ink-900)">Our </span><span style="color:var(--orange-500)">Mission,</span>{' '}
      <span style="color:var(--forest-800)">Vision</span>{' '}<span style="color:var(--ink-900)">&amp; </span><span style="color:var(--orange-500)">Values</span>
    </h2>
    <div class="heart-divider" style="justify-content:center;margin-bottom:48px" data-fade>
      <span class="line" style="width:60px"></span><span style="color:var(--heart)">♥</span><span class="line" style="width:60px"></span>
    </div>
    <div class="grid-3col" style="max-width:900px;margin:0 auto" data-stagger>
      {[
        { title:'Mission', img:'/illustrations/section-3-mission.webp', bg:'var(--orange-100)', body:'Cultivate kindness and positive character in children and families.' },
        { title:'Vision',  img:'/illustrations/section-3-vision.webp',  bg:'var(--orange-100)', body:'A kinder society where compassion grows in everyday life.' },
        { title:'Values',  img:'/illustrations/section-3-values.webp',  bg:'var(--sage-200)',   body:'Kindness, Compassion, Growth, Community.' },
      ].map(c => (
        <div class="card" style="padding:28px 18px;text-align:center">
          <div style={`width:100px;height:100px;border-radius:999px;background:${c.bg};margin:0 auto 16px;overflow:hidden`}>
            <img src={c.img} alt={c.title} style="width:100%;height:100%;object-fit:cover" loading="lazy" />
          </div>
          <div style="font:700 24px var(--serif);color:var(--forest-800);margin-bottom:8px">{c.title}</div>
          <span style="color:var(--heart)">♥</span>
          <p style="font:400 14px/1.6 var(--sans);color:var(--ink-700);margin-top:12px;margin-bottom:0">{c.body}</p>
        </div>
      ))}
    </div>
    <div data-fade style="margin-top:36px;display:flex;justify-content:center">
      <div class="card card--quiet" style="display:inline-flex;align-items:center;gap:8px;padding:10px 20px;border-radius:999px;max-width:100%">
        <span style="color:var(--fern-600)">🌱</span>
        <span style="font:500 13px/1.4 var(--sans);color:var(--ink-700)">
          Together, let's <strong style="color:var(--fern-600)">sow kindness</strong> and watch it <strong style="color:var(--fern-600)">grow.</strong>
        </span>
        <span style="color:var(--heart)">♥</span>
      </div>
    </div>
  </div>
</section>

<!-- ── WHAT WE DO ── -->
<section class="section section--cream">
  <div class="container">
    <div class="grid-2-1" style="margin-bottom:40px">
      <div data-fade>
        <h2 style="font:700 clamp(28px,5vw,64px)/1.1 var(--serif);margin:0 0 12px">
          <span style="color:var(--ink-900)">What </span><span style="color:var(--orange-500)">We Do</span>
        </h2>
        <div class="heart-divider" style="margin-bottom:12px"><span class="line"></span><span style="color:var(--heart)">♥</span><span class="line"></span></div>
        <p style="font:500 17px var(--sans);color:var(--ink-700);margin:0">Meaningful programmes that help kindness grow.</p>
      </div>
      <div data-fade class="blob-img-wrap" style="position:relative;width:120%;margin-left:-10%;aspect-ratio:1605/684;-webkit-mask-image:url(/illustrations/section-4-blob-mask.svg);mask-image:url(/illustrations/section-4-blob-mask.svg);-webkit-mask-size:100% 100%;mask-size:100% 100%;-webkit-mask-repeat:no-repeat;mask-repeat:no-repeat">
        <img src="/illustrations/section-4-community.png" alt="" style="width:100%;height:100%;object-fit:cover;display:block" loading="lazy" />
      </div>
    </div>
    <div class="grid-4col" data-stagger>
      {[
        { bg:'var(--sage-200)',   color:'var(--forest-800)', title:"Children's Kindness Initiatives", body:'Age-appropriate programmes nurturing empathy and everyday acts of kindness.' },
        { bg:'var(--orange-100)', color:'var(--orange-600)', title:'Storytelling, Arts & Crafts', body:'Through stories, art and imagination, children express and connect.' },
        { bg:'var(--orange-100)', color:'var(--orange-600)', title:'Community Outreach', body:'Reaching out through acts of service, inclusion and compassion.' },
        { bg:'var(--sage-200)',   color:'var(--forest-800)', title:'School Collaborations', body:'Partnering with schools to embed a culture of kindness.', highlight:true },
      ].map(p => (
        <div class="card" style={`padding:20px;background:${p.highlight ? 'var(--sage-50)' : 'var(--paper)'}`}>
          <span style={`display:inline-flex;width:44px;height:44px;border-radius:999px;background:${p.bg};color:${p.color};align-items:center;justify-content:center;margin-bottom:14px`}>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
            </svg>
          </span>
          <div style={`font:600 17px/1.3 var(--serif);color:${p.color};margin-bottom:8px`}>{p.title}</div>
          <p style="font:400 13px/1.55 var(--sans);color:var(--ink-700);margin:0">{p.body}</p>
        </div>
      ))}
    </div>
    <div style="text-align:center;margin-top:36px" data-fade>
      <a href="/events/upcoming/" class="btn btn-primary">Explore Upcoming Events <span class="chev">›</span></a>
    </div>
  </div>
</section>

<!-- ── STORIES TEASER ── -->
<section class="section" style="overflow:hidden;position:relative">
  <span class="float-heart" style="top:60px;left:14%;font-size:14px">♥</span>
  <span class="float-seed"  style="top:80px;right:12%;font-size:14px;animation-delay:1s">✻</span>
  <div class="container" style="text-align:center">
    <img data-fade src="/logo/sks-logo-transparent.png" alt="" width="110" height="110" style="height:110px;width:auto;margin:0 auto 12px" loading="lazy" />
    <h2 data-fade style="font:700 clamp(28px,4.5vw,60px)/1.1 var(--serif);margin:0">
      <span style="color:var(--ink-900)">Featured </span><span style="color:var(--orange-500)">Kindness</span>{' '}<span style="color:var(--ink-900)">Stories</span>
    </h2>
    <p data-fade style="font:500 16px var(--sans);color:var(--ink-500);margin:10px 0 36px">Ideas, inspiration and gentle stories for families.</p>
    <div class="grid-3col gap-24" data-stagger>
      {[
        { slug:'how-storytelling-helps-children-learn-kindness', tag:'Article', img:'/illustrations/section-5-image-1.png', title:'How Storytelling Helps Children Learn Kindness', body:'Discover how stories spark empathy and help children understand the world.' },
        { slug:'five-small-kindness-activities-for-your-saturday', tag:'Parenting', img:'/illustrations/section-5-image-2.png', title:'Simple Kindness Activities for Families', body:'Easy, meaningful ideas to nurture kindness at home and beyond.' },
        { slug:'growing-compassion-through-everyday-moments', tag:'Inspiration', img:'/illustrations/section-5-image-3.png', title:'Growing Compassion Through Everyday Moments', body:'Small acts, big impact — how daily moments help children grow kind.', play:true },
      ].map(s => (
        <a href={`/stories/${s.slug}/`} style="display:block;text-decoration:none;color:inherit">
          <div class="card" style="overflow:hidden">
            <div style="position:relative;height:200px">
              <img src={s.img} alt={s.title} style="width:100%;height:100%;object-fit:cover;display:block" loading="lazy" />
              <span class="pill pill--paper" style="position:absolute;left:14px;bottom:12px">{s.tag}</span>
              {s.play && <span style="position:absolute;right:14px;top:14px;width:34px;height:34px;border-radius:999px;background:rgba(255,255,255,.92);display:inline-flex;align-items:center;justify-content:center;color:var(--forest-800)"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg></span>}
            </div>
            <div style="padding:20px 22px 24px">
              <div style="font:600 20px/1.3 var(--serif);color:var(--ink-900);margin-bottom:10px">{s.title}</div>
              <p style="font:400 14px/1.6 var(--sans);color:var(--ink-700);margin:0">{s.body}</p>
            </div>
          </div>
        </a>
      ))}
    </div>
    <div style="margin-top:40px" data-fade>
      <a href="/stories/" class="btn btn-primary">View All Stories <span class="chev">›</span></a>
    </div>
  </div>
</section>

<!-- ── WATCH TEASER ── -->
<section class="section section--cream">
  <div class="container grid-1-15">
    <div data-fade>
      <div class="eyebrow"><span class="eyebrow__num">6</span><span class="eyebrow__label">Watch on GanjingWorld</span></div>
      <h2 style="font:700 clamp(28px,4.8vw,64px)/1.05 var(--serif);margin:18px 0 14px">
        <span style="color:var(--ink-900)">Inspiring</span><br/><span style="color:var(--forest-800)">Kindness</span><br/><span style="color:var(--orange-500)">Stories</span>
      </h2>
      <p style="font:400 15px/1.65 var(--sans);color:var(--ink-700);max-width:400px;margin-bottom:22px">Discover heartwarming stories on our official channel. Ad-free, family-safe.</p>
      <a href="/watch/" class="btn btn-secondary">Watch on GanjingWorld <span class="chev">›</span></a>
    </div>
    <div class="grid-2col-sm" data-stagger>
      {[
        { href:'https://www.ganjingworld.com/video/1ia1t1d4ree7wM4nzoEMtbywH1tp1c', img:'https://image1-ap-japan.cloudokyo.cloud/image/v3/6a/96/b2/6a96b2af-9920-4522-ae99-a6307771ad1c/1280.webp', title:'Lion and Mouse Friends', body:'A heartwarming animated song retelling the classic tale of kindness.' },
        { href:'https://www.ganjingworld.com/video/1ii0isdhvq42ypAN5bs9Fs9sp1of1c', img:'https://image1-ap-japan.cloudokyo.cloud/image/v14/b2/45/af/b245af9b-1785-4520-a705-6627c1d75254/1280.webp', title:'The Forgotten Swing', body:'Two children notice a lonely old man — small acts that change a life.' },
        { href:'https://www.ganjingworld.com/video/1g859k3l56b7kIcVYNot1b5rg1v91c', img:'https://image4-us-west.cloudokyo.cloud/image/v1/1d/0c/64/1d0c64c1-bab7-438b-99d5-c74ea8f2842b/1280.webp', title:"When I'm Feeling Kind", body:'A gentle story-time reading on what it feels like to be kind.' },
        { href:'https://www.ganjingworld.com/video/1icvovrk7pd6F44gZOc2jvmiO1mf1c', img:'https://image1-us-east.cloudokyo.cloud/image/v14/50/32/90/5032906e-26c4-4954-821b-285b18538e0c/1280.webp', title:'A Kind Man and the Plum Tree', body:'A Chinese traditional story about honesty, courtesy and kindness.' },
      ].map(v => (
        <a href={v.href} target="_blank" rel="noopener" class="card" style="padding:12px;text-align:center;display:block;color:inherit;text-decoration:none">
          <div style="position:relative;border-radius:14px;overflow:hidden;margin-bottom:12px;height:160px">
            <img src={v.img} alt={v.title} style="width:100%;height:100%;object-fit:cover" loading="lazy" />
            <span style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center">
              <span style="width:44px;height:44px;border-radius:999px;background:rgba(255,255,255,.92);display:inline-flex;align-items:center;justify-content:center;color:var(--forest-800)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              </span>
            </span>
          </div>
          <div style="font:600 15px/1.3 var(--serif);color:var(--forest-800);margin-bottom:6px">{v.title}</div>
          <p style="font:400 12px/1.5 var(--sans);color:var(--ink-700);margin:0">{v.body}</p>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ── EVENTS TEASER ── -->
<section class="section">
  <div class="container grid-1-2">
    <div data-fade>
      <div class="eyebrow"><span class="eyebrow__num">7</span><span class="eyebrow__label">Upcoming Events</span></div>
      <h2 style="font:700 clamp(28px,4.8vw,60px)/1.1 var(--serif);margin:18px 0 14px">
        <span style="color:var(--ink-900)">Join Our</span><br/><span style="color:var(--forest-800)">Upcoming</span>{' '}<span style="color:var(--orange-500)">Events</span>
      </h2>
      <p style="font:400 15px/1.65 var(--sans);color:var(--ink-700);max-width:360px;margin-bottom:22px">Join our events and be part of activities that inspire kindness across Singapore.</p>
      <a href="/events/upcoming/" class="btn btn-secondary">See All Events <span class="chev">›</span></a>
    </div>
    <div class="grid-2col-sm" data-stagger>
      {[
        { date:'21 Jun 2026', title:"Father's Day Celebration", body:'Art & craft activities where children create heartfelt keepsakes for the dads they love.' },
        { date:'20 Sep 2026', title:'Storytelling Competition 2026', body:'Submission deadline — bilingual storytelling for children aged 4–12.' },
        { date:'25 Sep 2026', title:'Mid-Autumn Festival', body:'Lantern-making for the whole family, celebrating togetherness and light.' },
        { date:'Early Dec 2026', title:'Christmas Programme', body:'Fill gift boxes with kindness promises and decorate ornaments for our tree.' },
      ].map(e => (
        <div class="card" style="padding:18px;text-align:center">
          <div style="display:flex;justify-content:center;align-items:center;gap:8px;color:var(--forest-800);margin-bottom:10px">
            <span style="width:32px;height:32px;border-radius:8px;background:var(--sage-50);display:inline-flex;align-items:center;justify-content:center">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </span>
            <span style="font:600 15px var(--sans)">{e.date}</span>
          </div>
          <div style="font:700 18px/1.25 var(--serif);color:var(--ink-900);margin-bottom:8px">{e.title}</div>
          <div class="heart-divider" style="justify-content:center"><span class="line" style="width:24px"></span><span style="color:var(--heart)">♥</span><span class="line" style="width:24px"></span></div>
          <p style="font:400 13px/1.6 var(--sans);color:var(--ink-700);margin:10px 0 0">{e.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── GET INVOLVED ── -->
<section class="section section--cream" style="overflow:hidden">
  <div class="container">
    <div class="grid-2col" style="margin-bottom:36px">
      <div data-fade>
        <div class="eyebrow"><span class="eyebrow__num">8</span><span class="eyebrow__label">Get Involved</span></div>
