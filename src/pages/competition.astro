---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Competition 2026 | Sowing Kindness Society" description="A bilingual storytelling competition for children aged 3–6 in Singapore. Register free, submit a video, win prizes.">

<section class="page-header">
  <div class="container">
    <div class="page-header__crumbs"><span>Competition</span><span class="dot"></span><span>Storytelling 2026</span></div>
    <h1 style="font:700 clamp(36px,5.5vw,72px)/1.06 var(--serif);letter-spacing:-.02em;margin:0 0 16px">
      <span style="color:var(--ink-900)">Sow Kindness, </span><span style="color:var(--orange-500)">Watch It Grow.</span><br/>
      <span style="color:var(--forest-800);font-size:.72em">Inter-Centres Storytelling Competition 2026</span>
    </h1>
    <p style="font:400 18px/1.6 var(--sans);color:var(--ink-700);max-width:680px;margin:0 0 10px">A bilingual storytelling competition for children aged 3 to 6, enrolled at a preschool, kindergarten, childcare, tuition or enrichment centre in Singapore.</p>
    <div style="display:flex;align-items:center;gap:10px;margin-top:16px">
      <span style="width:32px;height:1.5px;background:var(--sage-500);display:inline-block"></span>
      <span style="font:600 16px var(--serif);color:var(--fern-600)">播撒善意,静待花开</span>
      <span style="color:var(--heart)">♥</span>
    </div>
  </div>
</section>

<!-- CTAs -->
<section style="padding:28px 0 0">
  <div class="container">
    <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:28px">
      <a href="/submit/" class="btn btn-primary">Register Now <span class="chev">›</span></a>
      <a href="/rules/" class="btn btn-outline">Read the Official Rules</a>
    </div>
    <!-- Stats bar -->
    <div class="card card--quiet stats-bar" style="margin-bottom:0">
      <div class="stat-item">
        <span class="stat-icon" style="background:var(--sage-200)"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--forest-800)" stroke-width="2" stroke-linecap="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 3a4 4 0 100 8 4 4 0 000-8zM23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg></span>
        <div><div class="stat-label" style="color:var(--forest-800)">Ages 3–6</div><div class="stat-sub">Two categories</div></div>
      </div>
      <div class="stat-item">
        <span class="stat-icon" style="background:var(--sage-200)"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--forest-800)" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></span>
        <div><div class="stat-label" style="color:var(--forest-800)">3 or 5 min</div><div class="stat-sub">By age category</div></div>
      </div>
      <div class="stat-item">
        <span class="stat-icon" style="background:var(--sage-200)"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--forest-800)" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></span>
        <div><div class="stat-label" style="color:var(--forest-800)">20 Sep 2026</div><div class="stat-sub">Submission deadline</div></div>
      </div>
      <div class="stat-item">
        <span class="stat-icon" style="background:var(--orange-100)"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--orange-600)" stroke-width="2" stroke-linecap="round"><path d="M6 9H4.5a2.5 2.5 0 010-5H6M18 9h1.5a2.5 2.5 0 000-5H18M4 22h16M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22M18 2H6v7a6 6 0 0012 0V2z"/></svg></span>
        <div><div class="stat-label" style="color:var(--orange-600)">Nov 2026</div><div class="stat-sub">Grand Final</div></div>
      </div>
    </div>
  </div>
</section>

<!-- Theme -->
<section class="section" style="padding-top:52px">
  <div class="container grid-2col">
    <div data-stagger>
      <div class="eyebrow"><span class="eyebrow__num">01</span><span class="eyebrow__label">This year's theme</span></div>
      <h2 style="font:700 clamp(28px,4vw,52px)/1.1 var(--serif);margin:18px 0 14px">
        <span style="color:var(--ink-900)">A small act, </span><span style="color:var(--forest-800)">a big </span><span style="color:var(--orange-500)">heart.</span>
      </h2>
      <div class="heart-divider" style="margin-bottom:16px"><span class="line"></span><span style="color:var(--heart)">♥</span><span class="line"></span></div>
      <p style="font:400 17px/1.75 var(--sans);color:var(--ink-700);margin-bottom:14px">This year's competition invites children to share a story about a small act of kindness — something they saw, did, or wish for. A kind word. A shared snack. A helping hand.</p>
      <p style="font:400 17px/1.75 var(--sans);color:var(--ink-700);margin-bottom:14px">Stories can be told in English or Chinese. They can be true or made-up, and can include drawings, puppets, songs, soft toys, or just a child with a big imagination.</p>
      <p style="font:600 17px var(--serif);color:var(--fern-600);margin:0">We're not looking for perfect storytellers. We're listening for kind ones.</p>
    </div>
    <div data-fade class="blob-img-wrap" style="-webkit-mask-image:url(/illustrations/hero-blob-mask.svg);mask-image:url(/illustrations/hero-blob-mask.svg);-webkit-mask-size:100% 100%;mask-size:100% 100%;-webkit-mask-repeat:no-repeat;mask-repeat:no-repeat;aspect-ratio:1302/1208">
      <img src="/illustrations/storytellers-mic.png" alt="" style="width:100%;height:100%;object-fit:cover" loading="lazy" />
    </div>
  </div>
</section>

<!-- Judging -->
<section class="section section--cream">
  <div class="container">
    <div style="text-align:center;margin-bottom:40px" data-fade>
      <div class="eyebrow" style="justify-content:center;margin-bottom:10px"><span class="eyebrow__num">02</span><span class="eyebrow__label">How entries are judged</span></div>
      <h2 style="font:700 clamp(24px,4vw,52px)/1.1 var(--serif);margin:14px 0">
        <span style="color:var(--ink-900)">Four criteria, </span><span style="color:var(--forest-800)">judged with </span><span style="color:var(--orange-500)">care.</span>
      </h2>
    </div>
    <div class="grid-4col" data-stagger>
      {[
        { bg:'var(--orange-100)', color:'var(--orange-600)', pct:'30%', title:'Content & Relevance', body:'The story relates to kindness with a clear beginning, middle and end.' },
        { bg:'var(--sage-200)',   color:'var(--forest-800)', pct:'30%', title:'Delivery & Expression', body:'Voice, tone, facial expressions and body language.' },
        { bg:'var(--orange-100)', color:'var(--orange-600)', pct:'20%', title:'Creativity & Originality', body:'A unique story choice and imaginative use of props.' },
        { bg:'var(--sage-200)',   color:'var(--forest-800)', pct:'20%', title:'Stage Presence', body:'Poise, eye contact and the ability to engage the audience.' },
      ].map(c => (
        <div class="card" style="padding:22px">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
            <span style={`width:44px;height:44px;border-radius:999px;background:${c.bg};color:${c.color};display:inline-flex;align-items:center;justify-content:center`}>
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
            </span>
            <span style={`font:700 13px var(--sans);color:${c.color};background:${c.bg};padding:5px 12px;border-radius:999px`}>{c.pct}</span>
          </div>
          <div style={`font:700 18px var(--serif);color:var(--forest-800);margin-bottom:8px`}>{c.title}</div>
          <p style="font:400 14px/1.55 var(--sans);color:var(--ink-700);margin:0">{c.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Prizes -->
<section class="section">
  <div class="container">
    <div style="text-align:center;margin-bottom:40px" data-fade>
      <div class="eyebrow" style="justify-content:center;margin-bottom:10px"><span class="eyebrow__num">03</span><span class="eyebrow__label">Prizes</span></div>
      <h2 style="font:700 clamp(24px,4vw,52px)/1.1 var(--serif);margin:14px 0">
        <span style="color:var(--ink-900)">Every storyteller </span><span style="color:var(--forest-800)">leaves with </span><span style="color:var(--orange-500)">something.</span>
      </h2>
      <p style="font:500 17px var(--sans);color:var(--ink-700);max-width:560px;margin:0 auto">Winners chosen in each of the four groups — English &amp; Chinese, Categories A (3–4) and B (5–6).</p>
    </div>
    <div class="grid-3col gap-20" data-stagger>
      {[
        { tier:'Winner · each group', prize:'S$ 150', bg:'var(--orange-100)', color:'var(--orange-600)', highlight:true, perks:['Popular gift voucher','Trophy','Certificate of achievement'] },
        { tier:'1st Runner-Up · each group', prize:'S$ 100', bg:'var(--sage-200)', color:'var(--forest-800)', perks:['Popular gift voucher','Trophy','Certificate of achievement'] },
        { tier:'2nd Runner-Up · each group', prize:'S$ 50',  bg:'var(--sage-200)', color:'var(--forest-800)', perks:['Popular gift voucher','Trophy','Certificate of achievement'] },
      ].map(p => (
        <div class="card" style={`padding:28px 22px;text-align:center;position:relative;border:${p.highlight ? '2px solid var(--orange-600)' : 'none'}`}>
          {p.highlight && <span style="position:absolute;top:-13px;left:50%;transform:translateX(-50%);background:var(--orange-600);color:#fff;padding:6px 14px;border-radius:999px;font:700 11px var(--sans);letter-spacing:.06em;text-transform:uppercase">Grand Prize</span>}
          <div style={`width:76px;height:76px;border-radius:999px;background:${p.bg};color:${p.color};margin:0 auto 14px;display:inline-flex;align-items:center;justify-content:center`}>
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M6 9H4.5a2.5 2.5 0 010-5H6M18 9h1.5a2.5 2.5 0 000-5H18M4 22h16M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22M18 2H6v7a6 6 0 0012 0V2z"/></svg>
          </div>
          <div style="font:600 12px var(--sans);color:var(--ink-500);letter-spacing:.06em;text-transform:uppercase;margin-bottom:6px">{p.tier}</div>
          <div style={`font:700 30px var(--serif);color:var(--forest-800);margin-bottom:8px`}>{p.prize}</div>
          <div class="heart-divider" style="justify-content:center;margin-bottom:16px"><span class="line" style="width:20px"></span><span style="color:var(--heart)">♥</span><span class="line" style="width:20px"></span></div>
          <ul style="list-style:none;padding:0;margin:0;display:grid;gap:8px;font:400 14px/1.5 var(--sans);color:var(--ink-700);text-align:left">
            {p.perks.map(pk => <li style="display:flex;gap:8px"><span style="color:var(--fern-600)">✓</span><span>{pk}</span></li>)}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Timeline -->
<section class="section section--cream">
  <div class="container grid-tl">
    <div data-stagger>
      <div class="eyebrow"><span class="eyebrow__num">04</span><span class="eyebrow__label">Timeline</span></div>
      <h2 style="font:700 clamp(24px,4vw,52px)/1.1 var(--serif);margin:18px 0 14px">
        <span style="color:var(--ink-900)">From seed to </span><span style="color:var(--forest-800)">stage.</span>
      </h2>
      <p style="font:400 16px/1.7 var(--sans);color:var(--ink-700);max-width:360px;margin-bottom:22px">The competition runs across six months — gentle pace, plenty of time, no rush.</p>
      <div style="-webkit-mask-image:url(/illustrations/section-7-blob-mask.svg);mask-image:url(/illustrations/section-7-blob-mask.svg);-webkit-mask-size:100% 100%;mask-size:100% 100%;-webkit-mask-repeat:no-repeat;mask-repeat:no-repeat;aspect-ratio:1/1;max-width:300px">
        <img src="/illustrations/section-7-kids-planting.png" alt="" style="width:100%;height:100%;object-fit:cover" loading="lazy" />
      </div>
    </div>
    <div class="timeline" data-stagger>
      {[
        { status:'done',   date:'2026',                title:'Registration opens',          body:'Sign-ups open. A parent or guardian registers the child for free and completes the consent form.' },
        { status:'active', date:'Until 20 Sep 2026',   title:'Storytelling & submissions',  body:'Children record their story at home. Home phone recordings are very welcome.' },
        { status:'',       date:'20 September 2026',   title:'Round 1 — video deadline',   body:'Last day to upload your storytelling video. We acknowledge within 3 working days.' },
        { status:'',       date:'8 October 2026',      title:'Finalists notified',          body:'A panel of judges reviews every video and selects the finalists.' },
        { status:'',       date:'7 / 8 November 2026', title:'Round 2 — Grand Final (live)',body:'Six finalists from each group perform live on stage, 10.00 AM – 12.30 PM, Toa Payoh North (tentative).' },
      ].map(t => (
        <div class={`timeline__item ${t.status}`}>
          <div style={`font:600 13px var(--sans);color:${t.status==='active' ? 'var(--orange-600)' : 'var(--fern-600)'};letter-spacing:.04em;text-transform:uppercase;margin-bottom:4px`}>{t.date}</div>
          <div style="font:700 20px var(--serif);color:var(--forest-800);margin-bottom:6px">{t.title}</div>
          <p style="font:400 15px/1.6 var(--sans);color:var(--ink-700);margin:0;max-width:420px">{t.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="section">
  <div class="container grid-1-16">
    <div data-fade>
      <div class="eyebrow"><span class="eyebrow__num">05</span><span class="eyebrow__label">Questions & answers</span></div>
      <h2 style="font:700 clamp(24px,3.8vw,48px)/1.1 var(--serif);margin:18px 0 14px">
        <span style="color:var(--ink-900)">Asked by </span><span style="color:var(--forest-800)">parents </span><span style="color:var(--orange-500)">like you.</span>
      </h2>
      <p style="font:400 15px/1.7 var(--sans);color:var(--ink-700);max-width:340px;margin:0">Can't find your question? <a href="/contact/" style="color:var(--fern-600);font-weight:700;text-decoration:underline;text-underline-offset:4px">Send us a note</a> — we reply within two working days.</p>
    </div>
    <div style="display:grid;gap:12px" data-stagger>
      {[
        { q:'Is it really free to enter?', a:'Yes — registration is completely free. A parent or guardian registers the child and completes a consent form.' },
        { q:'My child is shy. Can they still take part?', a:'Absolutely. A story can be told in the quietest voice in the room. The judges listen for kindness, not confidence.' },
        { q:'Which language should my child perform in?', a:'The competition is bilingual — your child performs in either English or Chinese and is judged within that chosen language segment.' },
        { q:'Who can take part?', a:'Children aged 3 to 6 (as at 20 September 2026) enrolled at a preschool, kindergarten, childcare, tuition or enrichment centre in Singapore.' },
        { q:'What should the video look like?', a:'Phone recordings in landscape are perfect. A quiet room, soft natural light, and the child clearly in frame with audible sound is all we ask.' },
        { q:'Can my child use props, drawings or puppets?', a:'Please do. We love stories told with picture books, soft toys, paper puppets, costumes and quiet songs.' },
      ].map(f => (
        <details class="card card--flat" style="padding:16px 22px">
          <summary style="font:700 17px var(--serif);color:var(--forest-800);cursor:pointer;list-style:none;display:flex;align-items:center;justify-content:space-between;gap:12px">
            {f.q}
            <span style="width:28px;height:28px;border-radius:999px;background:var(--sage-50);display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--forest-800)">›</span>
          </summary>
          <p style="font:400 15px/1.7 var(--sans);color:var(--ink-700);margin:12px 0 0">{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- CTA -->
<section class="section section--cream" style="text-align:center;padding-top:72px;padding-bottom:72px">
  <div class="container">
    <h2 data-fade style="font:700 clamp(24px,4vw,52px)/1.1 var(--serif);margin:0 0 14px">
      <span style="color:var(--ink-900)">Ready to </span><span style="color:var(--forest-800)">share a </span><span style="color:var(--orange-500)">story?</span>
    </h2>
    <p data-fade style="font:500 17px var(--sans);color:var(--ink-700);max-width:480px;margin:0 auto 28px">The submission form takes about 5 minutes. Free to enter. Deadline 20 September 2026.</p>
    <div data-fade style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
      <a href="/submit/" class="btn btn-primary">Submit Your Video <span class="chev">›</span></a>
      <a href="/events/upcoming/" class="btn btn-outline">See Upcoming Events</a>
    </div>
  </div>
</section>

</BaseLayout>
