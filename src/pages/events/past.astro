---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Past Events | Sowing Kindness Society" description="A record of Sowing Kindness Society events — community gatherings, family days and kindness initiatives across Singapore.">
<section class="page-header">
  <div class="container">
    <div class="page-header__crumbs"><span>Events</span><span class="dot"></span><span>Past Events</span></div>
    <h1 style="font:700 clamp(36px,5.5vw,72px)/1.06 var(--serif);letter-spacing:-.02em;margin:0 0 14px;color:var(--forest-800)">Past Events</h1>
    <p style="font:400 18px/1.6 var(--sans);color:var(--ink-700);max-width:580px;margin:0">We're new — our first events are happening in 2026. Check back here after each gathering for a record of what we've been up to.</p>
  </div>
</section>
<section class="section" style="text-align:center">
  <div class="container" style="max-width:560px;margin:0 auto">
    <img src="/logo/sks-logomark.png" alt="" width="80" height="80" style="height:80px;width:auto;margin:0 auto 20px" />
    <h2 style="font:700 28px var(--serif);color:var(--forest-800);margin:0 0 12px">Just getting started.</h2>
    <p style="font:400 17px/1.7 var(--sans);color:var(--ink-700);margin:0 0 24px">Our first events are underway. This page will grow with each gathering, programme and kindness initiative we run across Singapore.</p>
    <a href="/events/upcoming/" class="btn btn-primary">See Upcoming Events <span class="chev">›</span></a>
  </div>
</section>
</BaseLayout>
