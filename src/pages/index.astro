</BaseLayout>

<script>
import { gsap } from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';
gsap.registerPlugin(ScrollTrigger);

// Hero — staggered word entrance
const words = document.querySelectorAll('#hero-heading .word');
const heroEls = ['#hero-sub','#hero-tagline','#hero-body','#hero-btns'].map(s => document.querySelector(s)).filter(Boolean);
const blob = document.getElementById('hero-blob');
const statsBar = document.getElementById('stats-bar');

const tl = gsap.timeline({ defaults: { ease: 'power4.out' } });
tl.from(words, { y: 40, stagger: 0.08, duration: 0.9, clearProps: 'transform' })
  .from(heroEls, { y: 18, stagger: 0.08, duration: 0.6, clearProps: 'transform' }, '-=0.3')
  .from(statsBar, { y: 24, duration: 0.65, clearProps: 'transform' }, '-=0.2');

if (blob) {
  tl.from(blob, { x: 50, scale: 0.97, duration: 1.1, ease: 'power3.out', clearProps: 'transform' }, 0.2);
  // Hero parallax
  gsap.to(blob, {
    y: -60, ease: 'none',
    scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom top', scrub: 2 },
  });
}
</script>
