---
const explore = [['/', 'Home'], ['/about/', 'About'], ['/stories/', 'Stories'], ['/watch/', 'Watch'], ['/events/upcoming/', 'Upcoming Events'], ['/events/past/', 'Past Events'], ['/contact/', 'Contact']];
const comp    = [['/competition/', 'Competition'], ['/rules/', 'Official Rules'], ['/consent/', 'Consent Form'], ['/submit/', 'Submit a Video']];
---
<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <img src="/logo/sks-logo-transparent.png" alt="Sowing Kindness Society" width="200" height="104"
          style="height:100px;width:auto;margin-bottom:14px;filter:brightness(0) invert(1)" />
        <p style="font:400 14px/1.6 var(--sans);margin:0;opacity:.85;max-width:320px">
          A Singapore-based non-profit nurturing kindness, compassion and positive values in children, families and communities.
        </p>
        <p style="font:400 13px/1.6 var(--sans);margin-top:14px;opacity:.7">Together, let's sow kindness and watch it grow.</p>
        <div style="display:flex;gap:10px;margin-top:18px">
          {[
            { href:'https://www.ganjingworld.com/@sowingkindness', label:'GanjingWorld', d:'M10 8l6 4-6 4V8z', fill:true },
            { href:'https://www.facebook.com/', label:'Facebook', d:'M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z', fill:true },
            { href:'https://www.instagram.com/', label:'Instagram', d:'M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37zm1.5-4.87h.01M7.5 21h9a3 3 0 003-3V6a3 3 0 00-3-3h-9a3 3 0 00-3 3v12a3 3 0 003 3z' },
          ].map(s => (
            <a href={s.href} target="_blank" rel="noopener" aria-label={s.label}
              style="width:38px;height:38px;border-radius:999px;background:rgba(255,255,255,.12);display:inline-flex;align-items:center;justify-content:center">
              <svg width="18" height="18" viewBox="0 0 24 24" fill={s.fill ? '#fff' : 'none'} stroke={s.fill ? 'none' : '#fff'} stroke-width="2" stroke-linecap="round">
                <path d={s.d} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <div>
        <h4 style="font:700 13px var(--sans);letter-spacing:.06em;text-transform:uppercase;color:#fff;margin-bottom:14px;margin-top:0">Explore</h4>
        <ul style="list-style:none;padding:0;margin:0;display:grid;gap:10px;font:400 14px var(--sans)">
          {explore.map(([href,label]) => <li><a href={href}>{label}</a></li>)}
        </ul>
      </div>

      <div>
        <h4 style="font:700 13px var(--sans);letter-spacing:.06em;text-transform:uppercase;color:#fff;margin-bottom:14px;margin-top:0">Competition</h4>
        <ul style="list-style:none;padding:0;margin:0;display:grid;gap:10px;font:400 14px var(--sans)">
          {comp.map(([href,label]) => <li><a href={href}>{label}</a></li>)}
        </ul>
      </div>

      <div>
        <h4 style="font:700 13px var(--sans);letter-spacing:.06em;text-transform:uppercase;color:#fff;margin-bottom:14px;margin-top:0">Stay Updated</h4>
        <p style="font:400 14px/1.5 var(--sans);opacity:.85;margin-bottom:12px">Gentle stories and updates, once a month.</p>
        <div style="display:flex;gap:8px">
          <input placeholder="you@email.com" style="flex:1;padding:12px 16px;border-radius:999px;border:none;font:400 14px var(--sans);background:rgba(255,255,255,.10);color:#fff;outline:none" />
          <button class="btn btn-primary" style="padding:12px 16px">Subscribe</button>
        </div>
      </div>
    </div>

    <hr />

    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;font:400 13px var(--sans);opacity:.7">
      <span>© 2026 Sowing Kindness Society Singapore. All rights reserved.</span>
      <span>
        Website by <a href="https://digitalreconnect.sg/" target="_blank" style="color:#fff;text-decoration:underline">Digital Reconnect</a>
        · <a href="/privacy/">Privacy</a> · <a href="/terms/">Terms</a>
      </span>
    </div>
  </div>
</footer>
