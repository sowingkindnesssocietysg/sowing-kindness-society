---
import BaseLayout from '../layouts/BaseLayout.astro';

const JUDGING = [
  { pct:'30%', title:'Content & Relevance', body:'The story relates meaningfully to the theme of kindness and has a clear beginning, middle and end.' },
  { pct:'30%', title:'Delivery & Expression', body:'Voice clarity, tone, facial expressions and body language enhance the storytelling experience.' },
  { pct:'20%', title:'Creativity & Originality', body:"A unique story choice and imaginative use of props, costumes or presentation." },
  { pct:'20%', title:'Stage Presence', body:"Poise, eye contact (with camera) and the ability to hold the audience's attention." },
];

const TIMELINE = [
  { done:true,   active:false, label:'Registration opens',  date:'June 2026' },
  { done:false,  active:true,  label:'Submission deadline', date:'20 September 2026, 11.59 PM' },
  { done:false,  active:false, label:'Finalists notified',  date:'October 2026' },
  { done:false,  active:false, label:'Grand Final',         date:'November 2026' },
];
---
<BaseLayout
  title="Official Rules | Sowing Kindness Society Storytelling Competition 2026"
  description="Full official rules for the Inter-Centres Storytelling Competition 2026. Eligibility, categories, video requirements, judging and prizes.">

<section class="page-header">
  <div class="container">
    <div class="page-header__crumbs">
      <a href="/competition/" style="color:var(--fern-600)">Competition</a>
      <span class="dot"></span>
      <span>Official Rules</span>
    </div>
    <h1 data-fade style="font:700 clamp(36px,5.5vw,72px)/1.06 var(--serif);letter-spacing:-.02em;margin:0 0 16px">
      <span style="color:var(--ink-900)">Official </span><span style="color:var(--forest-800)">Competition </span><span style="color:var(--orange-500)">Rules.</span>
    </h1>
    <p data-fade style="font:400 18px/1.6 var(--sans);color:var(--ink-700);max-width:640px;margin:0 0 20px">
      Inter-Centres Storytelling Competition 2026 — please read carefully before registering.
    </p>
    <div style="display:flex;gap:12px;flex-wrap:wrap">
      <a href="/submit/" class="btn btn-primary">Register Now <span class="chev">›</span></a>
      <a href="/consent/" class="btn btn-outline">View Consent Form</a>
    </div>
  </div>
</section>

<section class="section" style="padding-top:48px;padding-bottom:80px">
  <div class="container" style="max-width:820px">

    <!-- Quick summary -->
    <div class="card card--quiet rules-summary" style="padding:20px 28px;margin-bottom:52px;display:grid;grid-template-columns:repeat(4,1fr);gap:16px;text-align:center">
      <div><div style="font:700 20px var(--serif);color:var(--forest-800)">3 – 6 yrs</div><div style="font:500 12px var(--sans);color:var(--ink-500);margin-top:2px">Age range</div></div>
      <div><div style="font:700 20px var(--serif);color:var(--forest-800)">EN / 中文</div><div style="font:500 12px var(--sans);color:var(--ink-500);margin-top:2px">Language</div></div>
      <div><div style="font:700 20px var(--serif);color:var(--forest-800)">20 Sep 2026</div><div style="font:500 12px var(--sans);color:var(--ink-500);margin-top:2px">Deadline</div></div>
      <div><div style="font:700 20px var(--serif);color:var(--forest-800)">Free</div><div style="font:500 12px var(--sans);color:var(--ink-500);margin-top:2px">Entry fee</div></div>
    </div>

    <!-- Section 1 -->
    <div data-fade style="margin-bottom:48px">
      <div style="display:flex;align-items:center;gap:14px;margin-bottom:18px">
        <span class="rule-num">1</span>
        <h2 class="rule-title">About the Competition</h2>
      </div>
      <div style="padding-left:52px">
        <p class="article-p">The Inter-Centres Storytelling Competition 2026 ("the Competition") is organised by Sowing Kindness Society, a Singapore-based non-profit. The Competition is open to children enrolled at preschools, kindergartens, childcare centres, tuition centres and enrichment centres in Singapore.</p>
        <p class="article-p">The aim of the Competition is to nurture creativity, confidence and kindness in young children through the art of storytelling.</p>
      </div>
    </div>

    <!-- Section 2 -->
    <div data-fade style="margin-bottom:48px">
      <div style="display:flex;align-items:center;gap:14px;margin-bottom:18px">
        <span class="rule-num">2</span>
        <h2 class="rule-title">Eligibility</h2>
      </div>
      <div style="padding-left:52px">
        <ul class="article-ul">
          <li>The participant must be aged 3 to 6 years old at the time of the submission deadline (20 September 2026).</li>
          <li>The participant must be currently enrolled at a preschool, kindergarten, childcare, tuition or enrichment centre in Singapore.</li>
          <li>Each child may submit only one entry per competition year.</li>
          <li>There is no limit on the number of entries per centre.</li>
          <li>Entry is open to Singapore citizens, permanent residents and foreigners enrolled at a qualifying Singapore centre.</li>
          <li>Entries must be submitted by a parent or legal guardian on behalf of the child.</li>
        </ul>
      </div>
    </div>

    <!-- Section 3 -->
    <div data-fade style="margin-bottom:48px">
      <div style="display:flex;align-items:center;gap:14px;margin-bottom:18px">
        <span class="rule-num">3</span>
        <h2 class="rule-title">Competition Categories</h2>
      </div>
      <div style="padding-left:52px">
        <p class="article-p">There are two age categories:</p>
        <div class="grid-2col-sm" style="margin:16px 0 24px">
          <div class="card" style="padding:22px;background:var(--sage-50)">
            <div style="font:700 13px var(--sans);color:var(--forest-800);letter-spacing:.06em;text-transform:uppercase;margin-bottom:8px">Category A</div>
            <div style="font:700 24px var(--serif);color:var(--ink-900);margin-bottom:6px">Age 3 to 4</div>
            <div style="font:600 15px var(--sans);color:var(--fern-600)">3-minute story</div>
          </div>
          <div class="card" style="padding:22px;background:var(--orange-100)">
            <div style="font:700 13px var(--sans);color:var(--orange-700);letter-spacing:.06em;text-transform:uppercase;margin-bottom:8px">Category B</div>
            <div style="font:700 24px var(--serif);color:var(--ink-900);margin-bottom:6px">Age 5 to 6</div>
            <div style="font:600 15px var(--sans);color:var(--orange-700)">5-minute story</div>
          </div>
        </div>
        <p class="article-p">The child's age is determined as of the submission deadline date (20 September 2026).</p>
      </div>
    </div>

    <!-- Section 4 -->
    <div data-fade style="margin-bottom:48px">
      <div style="display:flex;align-items:center;gap:14px;margin-bottom:18px">
        <span class="rule-num">4</span>
        <h2 class="rule-title">Theme</h2>
      </div>
      <div style="padding-left:52px">
        <div class="article-tip"><p><strong>"A small act, a big heart."</strong> — Children are invited to share a story about a small act of kindness: something they saw, did, or wish for. A kind word. A shared snack. A helping hand.</p></div>
        <p class="article-p">Stories can be true or made-up. They may include drawings, puppets, songs, soft toys, picture books or props. We are not looking for perfect storytellers — we are listening for kind ones.</p>
        <p class="article-p">Stories may be told in English or Chinese (Mandarin). Bilingual stories (portions in both languages) are also welcome.</p>
      </div>
    </div>

    <!-- Section 5 -->
    <div data-fade style="margin-bottom:48px">
      <div style="display:flex;align-items:center;gap:14px;margin-bottom:18px">
        <span class="rule-num">5</span>
        <h2 class="rule-title">Video Submission Requirements</h2>
      </div>
      <div style="padding-left:52px">
        <h3 class="article-h3">Format</h3>
        <ul class="article-ul">
          <li>File format: MP4 or MOV (phone recordings are perfectly acceptable).</li>
          <li>Orientation: landscape (horizontal) preferred; portrait (vertical) accepted.</li>
          <li>Minimum resolution: 720p (1280×720). HD 1080p preferred.</li>
          <li>Maximum file size: 500 MB.</li>
        </ul>
        <h3 class="article-h3">Duration</h3>
        <ul class="article-ul">
          <li>Category A (Age 3–4): maximum 3 minutes.</li>
          <li>Category B (Age 5–6): maximum 5 minutes.</li>
          <li>Videos that exceed the time limit will be judged only on the first 3 or 5 minutes respectively.</li>
        </ul>
        <h3 class="article-h3">Content guidelines</h3>
        <ul class="article-ul">
          <li>The child must be clearly visible and audible throughout the storytelling portion.</li>
          <li>The video must be a single continuous take or a simple edit of the child telling the story.</li>
          <li>Background music is permitted but must not overpower the child's voice.</li>
          <li>Excessive post-production effects are discouraged; natural, authentic storytelling is valued.</li>
          <li>The video must not contain any content that is offensive, violent, discriminatory or otherwise inappropriate.</li>
        </ul>
        <h3 class="article-h3">How to submit</h3>
        <ul class="article-ul">
          <li>Upload your video to Google Drive, YouTube (Unlisted) or WeTransfer, then submit the link via the <a href="/submit/" style="color:var(--fern-600);font-weight:600">registration form</a>.</li>
          <li>Alternatively, email the link to <strong>contact@sowingkindness.org.sg</strong> with your child's name and category in the subject line.</li>
          <li>The submission link must remain accessible until at least 31 December 2026.</li>
        </ul>
      </div>
    </div>

    <!-- Section 6 -->
    <div data-fade style="margin-bottom:48px">
      <div style="display:flex;align-items:center;gap:14px;margin-bottom:18px">
        <span class="rule-num">6</span>
        <h2 class="rule-title">Judging Criteria</h2>
      </div>
      <div style="padding-left:52px">
        <p class="article-p">Entries will be assessed by an independent panel across four criteria:</p>
        <div style="display:grid;gap:12px;margin:16px 0 20px">
          {JUDGING.map(c => (
            <div style="display:flex;gap:16px;align-items:flex-start;padding:16px 18px;border-radius:14px;background:var(--cream-200)">
              <span style="font:700 18px var(--serif);color:var(--forest-800);flex-shrink:0;min-width:44px">{c.pct}</span>
              <div>
                <div style="font:700 15px var(--sans);color:var(--ink-900);margin-bottom:3px">{c.title}</div>
                <p style="font:400 14px/1.55 var(--sans);color:var(--ink-700);margin:0">{c.body}</p>
              </div>
            </div>
          ))}
        </div>
        <p class="article-p">Judges' decisions are final and no correspondence will be entered into regarding scoring.</p>
      </div>
    </div>

    <!-- Section 7 -->
    <div data-fade style="margin-bottom:48px">
      <div style="display:flex;align-items:center;gap:14px;margin-bottom:18px">
        <span class="rule-num">7</span>
        <h2 class="rule-title">Competition Rounds</h2>
      </div>
      <div style="padding-left:52px">
        <h3 class="article-h3">Round 1 — Video Submissions (Online)</h3>
        <p class="article-p">All eligible entries received by 20 September 2026 will be reviewed by the judging panel. Shortlisted finalists will be notified by October 2026 and invited to the Grand Final.</p>
        <h3 class="article-h3">Round 2 — Grand Final (Live)</h3>
        <p class="article-p">Shortlisted children will perform their story live at the Grand Final event in November 2026. The venue and exact date will be confirmed to finalists upon selection. Parents or guardians are responsible for transport and attendance.</p>
        <p class="article-p">Participation in the Grand Final constitutes acceptance of these rules in full, including consent to photography and videography for competition documentation and publicity.</p>
      </div>
    </div>

    <!-- Section 8 -->
    <div data-fade style="margin-bottom:48px">
      <div style="display:flex;align-items:center;gap:14px;margin-bottom:18px">
        <span class="rule-num">8</span>
        <h2 class="rule-title">Prizes</h2>
      </div>
      <div style="padding-left:52px">
        <p class="article-p">Prizes will be awarded for each category at the Grand Final. Full prize details will be announced closer to the event.</p>
        <ul class="article-ul">
          <li>Champion, 1st Runner-Up and 2nd Runner-Up will be recognised in each category.</li>
          <li>All Grand Final participants receive a Certificate of Achievement.</li>
          <li>All Round 1 participants receive a digital Certificate of Participation.</li>
          <li>Prizes are non-transferable and cannot be exchanged for cash.</li>
        </ul>
      </div>
    </div>

    <!-- Section 9 -->
    <div data-fade style="margin-bottom:48px">
      <div style="display:flex;align-items:center;gap:14px;margin-bottom:18px">
        <span class="rule-num">9</span>
        <h2 class="rule-title">Key Dates</h2>
      </div>
      <div style="padding-left:52px">
        <div class="timeline" style="margin-top:8px">
          {TIMELINE.map(t => (
            <div class={`timeline__item${t.done ? ' done' : ''}${t.active ? ' active' : ''}`}>
              <div style="font:700 15px var(--sans);color:var(--forest-800)">{t.label}</div>
              <div style="font:500 13px var(--sans);color:var(--ink-500);margin-top:2px">{t.date}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Section 10 -->
    <div data-fade style="margin-bottom:48px">
      <div style="display:flex;align-items:center;gap:14px;margin-bottom:18px">
        <span class="rule-num">10</span>
        <h2 class="rule-title">General Terms & Conditions</h2>
      </div>
      <div style="padding-left:52px">
        <ul class="article-ul">
          <li>Entry is free. No purchase is necessary.</li>
          <li>By submitting an entry, the parent or guardian confirms that all information is accurate and that they have read and agreed to these rules and the Parental Consent Form.</li>
          <li>Sowing Kindness Society reserves the right to disqualify any entry that does not comply with these rules or that contains inappropriate content.</li>
          <li>Sowing Kindness Society reserves the right to use submitted videos, photographs and the child's first name for competition documentation, website content, social media and publicity. Parents may opt out by indicating this on the registration form.</li>
          <li>Personal data collected during registration will be used solely for the administration of the Competition and handled in accordance with Singapore's Personal Data Protection Act (PDPA).</li>
          <li>The organisers accept no liability for technical issues during video upload or submission.</li>
          <li>These rules may be updated at any time. The most current version will always be at sowingkindness.org.sg/rules.</li>
          <li>Sowing Kindness Society's decision on all matters relating to the Competition is final.</li>
        </ul>
      </div>
    </div>

    <!-- Contact strip -->
    <div data-fade class="card" style="padding:28px 32px;background:var(--sage-50);border-radius:20px;display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;margin-top:16px">
      <div>
        <div style="font:700 18px var(--serif);color:var(--forest-800);margin-bottom:6px">Questions about the rules?</div>
        <p style="font:400 14px var(--sans);color:var(--ink-700);margin:0">Email <strong>contact@sowingkindness.org.sg</strong> — we respond within two business days.</p>
      </div>
      <a href="/contact/" class="btn btn-secondary" style="flex-shrink:0">Contact Us <span class="chev">›</span></a>
    </div>

    <!-- Bottom CTAs -->
    <div data-fade style="display:flex;gap:12px;flex-wrap:wrap;margin-top:36px">
      <a href="/submit/" class="btn btn-primary">Register Now <span class="chev">›</span></a>
      <a href="/consent/" class="btn btn-outline">View Consent Form</a>
      <a href="/competition/" class="btn btn-outline">Back to Competition</a>
    </div>

  </div>
</section>

</BaseLayout>

<style>
.rule-num {
  width:38px;height:38px;border-radius:999px;
  background:var(--sage-200);color:var(--forest-800);
  font:700 16px var(--sans);
  display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;
}
.rule-title {
  font:700 clamp(18px,2.5vw,26px)/1.2 var(--serif);
  color:var(--forest-800);margin:0;
}
@media(max-width:639px){
  .rules-summary { grid-template-columns:repeat(2,1fr)!important }
  [style*="padding-left:52px"] { padding-left:0!important }
  [style*="display:flex;align-items:center;gap:14px;margin-bottom:18px"] { margin-bottom:14px }
}
</style>
