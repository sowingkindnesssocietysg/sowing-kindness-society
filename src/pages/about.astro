---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About | Sowing Kindness Society" description="Sowing Kindness Society is a Singapore-based non-profit promoting kindness in children, families and communities.">

<section class="page-header">
  <div class="container">
    <div class="page-header__crumbs"><span>About</span><span class="dot"></span><span>Who We Are</span></div>
    <h1 data-fade style="font:700 clamp(36px,5.5vw,72px)/1.06 var(--serif);letter-spacing:-.02em;margin:0 0 18px">
      <span style="color:var(--ink-900)">Nurturing kindness in </span><span style="color:var(--forest-800)">children, families </span><span style="color:var(--orange-500)">and communities.</span>
    </h1>
    <p data-fade style="font:400 18px/1.6 var(--sans);color:var(--ink-700);max-width:660px;margin:0">
      Sowing Kindness Society is a Singapore-based non-profit promoting kindness, compassion and positive values through meaningful initiatives, family engagement and community activities.
    </p>
  </div>
</section>

<!-- Story -->
<section class="section" style="padding-top:64px">
  <div class="container grid-2col">
    <div data-fade class="blob-img-wrap" style="position:relative;width:110%;margin-left:-5%;aspect-ratio:1045/941;-webkit-mask-image:url(/illustrations/section-2-blob-mask.svg);mask-image:url(/illustrations/section-2-blob-mask.svg);-webkit-mask-size:100% 100%;mask-size:100% 100%;-webkit-mask-repeat:no-repeat;mask-repeat:no-repeat">
      <img src="/illustrations/section-2-about.png" alt="" style="width:100%;height:100%;object-fit:cover" loading="lazy" />
    </div>
    <div data-stagger>
      <div class="eyebrow"><span class="eyebrow__num">01</span><span class="eyebrow__label">Our story</span></div>
      <h2 style="font:700 clamp(24px,4vw,52px)/1.1 var(--serif);margin:18px 0 14px">
        <span style="color:var(--ink-900)">A small society </span><span style="color:var(--forest-800)">with a big </span><span style="color:var(--orange-500)">garden.</span>
      </h2>
      <p style="font:400 17px/1.75 var(--sans);color:var(--ink-700);margin-bottom:14px">Sowing Kindness Society began as a small circle of parents, educators and storytellers who shared one belief: kindness is something we can grow in our youngest children, one moment, one story, one act at a time.</p>
      <p style="font:400 17px/1.75 var(--sans);color:var(--ink-700);margin-bottom:14px">From quiet picture-book afternoons in neighbourhood living rooms, we have grown into a bilingual movement that holds an annual storytelling competition for children aged 3 to 6, runs school collaborations across Singapore, and gathers families through gentle, joyful events.</p>
      <p style="font:400 17px/1.75 var(--sans);color:var(--ink-700);margin:0">We're still small. We still believe in slow, careful work — like a gardener tending a young seedling. Thank you for tending it with us.</p>
    </div>
  </div>
</section>

<!-- MVV -->
<section class="section section--cream">
  <div class="container" style="text-align:center">
    <div class="eyebrow" style="justify-content:center;margin-bottom:8px" data-fade><span class="eyebrow__num">02</span><span class="eyebrow__label">Mission, vision &amp; values</span></div>
    <h2 data-fade style="font:700 clamp(24px,4.5vw,60px)/1.1 var(--serif);margin:16px 0 12px">
      <span style="color:var(--ink-900)">What guides </span><span style="color:var(--forest-800)">everything </span><span style="color:var(--orange-500)">we do.</span>
    </h2>
    <div class="heart-divider" style="justify-content:center;margin-bottom:48px" data-fade><span class="line" style="width:60px"></span><span style="color:var(--heart)">♥</span><span class="line" style="width:60px"></span></div>
    <div class="grid-3col" style="max-width:1080px;margin:0 auto" data-stagger>
      {[
        { title:'Mission', img:'/illustrations/section-3-mission.webp', bg:'var(--orange-100)', body:'Cultivate kindness and positive character in children and families through stories, programmes and community.' },
        { title:'Vision',  img:'/illustrations/section-3-vision.webp',  bg:'var(--orange-100)', body:'A kinder Singapore where compassion grows in everyday life — in homes, in schools, on buses and in playgrounds.' },
        { title:'Values',  img:'/illustrations/section-3-values.webp',  bg:'var(--sage-200)',   body:'Kindness, compassion, growth and community — the four seeds at the centre of every programme.' },
      ].map(c => (
        <div class="card" style="padding:28px 20px;text-align:center">
          <div style={`width:100px;height:100px;border-radius:999px;background:${c.bg};margin:0 auto 16px;overflow:hidden`}>
            <img src={c.img} alt={c.title} style="width:100%;height:100%;object-fit:cover" loading="lazy" />
          </div>
          <div style="font:700 24px var(--serif);color:var(--forest-800);margin-bottom:8px">{c.title}</div>
          <span style="color:var(--heart)">♥</span>
          <p style="font:400 14px/1.6 var(--sans);color:var(--ink-700);margin-top:12px;margin-bottom:0">{c.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Team -->
<section class="section">
  <div class="container" style="text-align:center">
    <div class="eyebrow" style="justify-content:center;margin-bottom:8px" data-fade><span class="eyebrow__num">03</span><span class="eyebrow__label">The gardeners</span></div>
    <h2 data-fade style="font:700 clamp(24px,4vw,56px)/1.1 var(--serif);margin:16px 0 14px">
      <span style="color:var(--ink-900)">A small team </span><span style="color:var(--forest-800)">tending </span><span style="color:var(--orange-500)">the garden.</span>
    </h2>
    <div class="grid-3col" style="max-width:860px;margin:36px auto 0" data-stagger>
      {[
        { name:'Celina Loh',  role:'Founder',  initials:'CL', bg:'var(--orange-100)', fg:'var(--orange-600)' },
        { name:'Mandy Teoh', role:'Secretary', initials:'MT', bg:'var(--sage-200)',   fg:'var(--forest-800)' },
        { name:'Shaney Koh', role:'Treasurer', initials:'SK', bg:'var(--orange-100)', fg:'var(--orange-600)' },
      ].map(p => (
        <div class="card" style="padding:26px 20px;text-align:center">
          <div style={`width:100px;height:100px;border-radius:999px;background:${p.bg};color:${p.fg};font:700 32px var(--serif);display:inline-flex;align-items:center;justify-content:center;margin:0 auto 12px`}>{p.initials}</div>
          <div style="font:700 20px var(--serif);color:var(--forest-800);margin-bottom:4px">{p.name}</div>
          <div style="font:500 14px var(--sans);color:var(--ink-500)">{p.role}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA -->
<section class="section section--cream" style="padding-top:80px;padding-bottom:80px">
  <div class="container grid-2col">
    <div data-fade>
      <h2 style="font:700 clamp(24px,4vw,52px)/1.1 var(--serif);margin:0 0 16px">
        <span style="color:var(--ink-900)">Plant a seed </span><span style="color:var(--forest-800)">with us.</span>
      </h2>
      <p style="font:400 17px/1.7 var(--sans);color:var(--ink-700);max-width:460px;margin-bottom:22px">Whether you partner with us, help host an event, or simply share a story with the children in your life — there are many gentle ways to take part.</p>
      <div style="display:flex;gap:12px;flex-wrap:wrap">
        <a href="/contact/" class="btn btn-primary">Get in Touch <span class="chev">›</span></a>
        <a href="/competition/" class="btn btn-outline">View Competition</a>
      </div>
    </div>
    <div data-fade class="blob-img-wrap" style="position:relative;max-width:500px;margin:0 auto;aspect-ratio:1/1;-webkit-mask-image:url(/illustrations/about-cta-blob.svg);mask-image:url(/illustrations/about-cta-blob.svg);-webkit-mask-size:100% 100%;mask-size:100% 100%;-webkit-mask-repeat:no-repeat;mask-repeat:no-repeat">
      <img src="/illustrations/about-cta.webp" alt="" style="width:100%;height:100%;object-fit:cover" loading="lazy" />
    </div>
  </div>
</section>

</BaseLayout>
